## 复制为 .env 并填写（不要提交/不要发到聊天里）

# 服务监听（可选）。默认监听所有网卡，方便同事在同一 WiFi 用浏览器打开；仅本机访问可设 HOST=127.0.0.1
# HOST=0.0.0.0
# PORT=8000

# share_public.py 可选：仅用 ngrok（需 pip install pyngrok）
# PUBLIC_USE_NGROK=1
# NGROK_AUTHTOKEN=你的_ngrok_令牌

# 豆包/火山方舟（ARK）配置（推荐用 DOUBAO_*）
DOUBAO_API_KEY=你的_API_KEY
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 未设置时默认 doubao-lite-4k；方舟上常为推理接入点 ID（ep-…），以控制台为准
DOUBAO_MODEL=doubao-lite-4k

# 默认开启 JSON 模式（更易解析）；若 chat/completions 返回 400，可设 DOUBAO_JSON_OBJECT=0

# AI 速度与超时：单次请求 HTTP 读超时（秒），过短会反复超时重试、页面长时间空白
# AI_READ_TIMEOUT=120
# AI_READ_TIMEOUT_STEP=40
# AI_READ_TIMEOUT_MAX=240
# 默认非流式（经隧道更稳）；需要流式可设 DOUBAO_STREAM=1
# DOUBAO_STREAM=0
# 输出长度上限（略降可加快生成）
# AI_MAX_TOKENS_DIAGNOSE=768
# AI_MAX_TOKENS_ADVISE=768

# 可选：自定义 Prompt（{case} 会替换为 JSON 字符串）
# 诊断默认：CPR 拆解 + path_you/path_them + emotion_why_both；建议默认：仅含 diagnosis 摘要，不含 STAR 复述
# DOUBAO_SYSTEM_PROMPT=只输出JSON。
# DOUBAO_PROMPT_DIAGNOSE=... 案例{case}
# DOUBAO_PROMPT_ADVISE=... 输入{case}

# 兼容旧写法（可不填）
# OPENAI_API_KEY=你的_API_KEY
# OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# OPENAI_MODEL=你的_Endpoint_ID_例如_ep-xxxxxxxxxxxx

